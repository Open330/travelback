{
  "name": "travelback",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/serve-static.mjs --base-path /travelback",
    "preview": "npm run start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:dev": "playwright test -c playwright.config.ts",
    "test:e2e:static": "npm run build && playwright test -c playwright.static.config.ts",
    "smoke:static": "node scripts/smoke-static.mjs"
  },
  "dependencies": {
    "@tmcw/togeojson": "^7.1.2",
    "lucide-react": "^0.575.0",
    "maplibre-gl": "^5.18.0",
    "mediabunny": "^1.34.4",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
